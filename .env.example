# toolscout configuration — copy to .env and fill in. Models are referred to by ROLE, never hardcoded.
# NOTE: nothing here is auto-loaded; source it yourself (`set -a; . ./.env; set +a`) or export the vars.

# --- Models: planner + specialist on one OpenAI-compatible proxy (the default path) ---
# Model ids are the PLAIN id your endpoint serves (e.g. gpt-4o-mini) — use the bare id on EVERY role, no
# `openai/` (or other litellm) provider prefix. The planner/specialist route via litellm (which also
# tolerates a legacy `openai/...`), but the judge/rubric/eval clients send the id VERBATIM, so a prefix
# there would 404 — bare is the one convention that works on every role.
# PLANNER (root LM): a small, cheap orchestrator that drives the ISL -> ITL -> PTC REPL loop.
TS_ROOT_LM=gpt-4o-mini
# SPECIALIST (sub LM, reached via llm_query): an expensive brain the planner escalates a subtle
# sub-question to. Can equal the planner.
TS_SUB_LM=gpt-4o-mini
TS_BASE_URL=https://api.openai.com/v1
TS_API_KEY=sk-...

# --- OR: run planner + specialist on a Claude Pro/Max SUBSCRIPTION (no API key) ---
# Give a role the `claude-agent-sdk/<id>` prefix and it runs on your personal Claude subscription via
# the official Claude Agent SDK (rlm-kit's `rlm_kit.ClaudeAgentLM`, the `[subscription]` extra) — each
# call a pure completion (no tools). Prerequisites: `uv sync --extra subscription`; the Claude Code CLI
# installed and logged in (`claude` -> /login, or `claude setup-token` -> export CLAUDE_CODE_OAUTH_TOKEN);
# and `unset ANTHROPIC_API_KEY` (a leftover key would bill API credit; the adapter refuses to start).
# The JUDGE role may NOT use the sentinel — it is a separate OpenAI-compatible endpoint (mixed auth).
# TS_ROOT_LM=claude-agent-sdk/claude-sonnet-5
# TS_SUB_LM=claude-agent-sdk/claude-fable-5

# --- The toolspace (external MCP servers — a TRUST declaration) ---
# Path to a JSON list of MCP server specs; unset uses a small built-in demo catalog (offline-safe).
# Each spec: {"name","description","command","args","env"} (stdio) or {"name","description","url"} (HTTP).
# A curated, security-domain starter ships as `toolspace.example.json` (two hosted, no-key, first-party
# HTTP servers: ProjectDiscovery Security Context + the official Have I Been Pwned). Copy it and edit:
#   cp toolspace.example.json toolspace.json     # then point at it below (see the toolscout/ guide's
# TS_TOOLSPACE=./toolspace.json                  # "The toolspace" section for the vetted opt-in catalog)
# "eager" (default): connect all servers host-side pre-run (hang-safe), disclose schemas lazily.
# "lazy" (experimental): defer connection until a server is selected (only after a live-safety spike).
TS_CONNECT=eager
# MCP transport bound (seconds): per-server connect + per-call + close. A DEDICATED knob, never the
# judge's timeout — a snappy-judge setting must not make a slow-starting MCP server fail at connect.
TS_MCP_TIMEOUT=60
# Server/tool descriptions + schemas are UNTRUSTED server-authored text; cap what enters the REPL.
TS_MAX_DESC_CHARS=1200
TS_MAX_DESCRIBE_BATCH=8
# PTC repeat guard: identical (server, tool, args) dispatches allowed per run before call_tool refuses
# with guiding text (breaks an unconscious re-fetch loop / identical-args retry storm before it hammers
# a third-party server). 0 (or negative) disables. Raise it for legitimate same-args polling.
TS_MAX_REPEAT_CALLS=3

# --- The OPT-IN rubric judge (a verify-before-finalize self-check; OFF by default) ---
# Emits per-criterion OBSERVATIONS (labels), never a reward. Off keeps the run purest w.r.t. the
# "trajectories, never reward" boundary. When on, it is a separate OpenAI-compatible endpoint.
TS_ENABLE_JUDGE=0
# TS_JUDGE_LM=qwen/qwen3-30b
# TS_JUDGE_BASE_URL=https://your-judge-endpoint/v1
# TS_JUDGE_API_KEY=...

# --- Host-side rubric GENERATION (optional; dataset-prep, NOT a planner tool) ---
# `toolscout rubric "<task>"` calls a frontier model once per task, offline, to decompose the rubric.
# TS_RUBRIC_LM=gpt-5
# TS_RUBRIC_BASE_URL=https://api.openai.com/v1
# TS_RUBRIC_API_KEY=sk-...

# --- RLM runtime knobs ---
TS_INTERPRETER=pyodide       # the sandbox is the boundary; a live run also needs `brew install deno`
TS_ADAPTER=json
TS_PLANNER_MAX_TOKENS=16384
TS_MAX_ITERATIONS=45         # HARD per-run cap; 45 gives ATLAS discovery over a large toolspace headroom
TS_MAX_LLM_CALLS=8           # caps specialist (llm_query) escalations only
TS_MAX_OUTPUT_CHARS=8000     # head+tail char cap dspy.RLM applies to each REPL output
TS_ENABLE_SKILLS=1
TS_OBSERVE=0

# --- studio (visualization console) ---
# TS_ARTIFACTS_DIR=./output

# --- eval harness (toolscout-eval; a reward-free MEASUREMENT judge, SEPARATE from the rollout) ---
# `toolscout-eval score/run` scores completed trajectories with a 4-category (TF/TA/TG/PA) 0-10 judge to
# REPORT quality — it NEVER feeds a reward back into a trajectory/dataset (that's the training project's
# job). This judge is its OWN OpenAI-compatible endpoint; use a strong, INDEPENDENT model (the paper uses
# an external o4-mini-class judge), deliberately not the planner/rollout model.
# TSEVAL_MODEL=o4-mini
# TSEVAL_BASE_URL=https://api.openai.com/v1
# TSEVAL_API_KEY=sk-...
# TSEVAL_TIMEOUT=60
